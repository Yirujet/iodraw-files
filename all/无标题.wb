 const dep = new Dep()\n\n    Object.defineProperty(obj, key,  {\n        enumerable: true,\n        configurable: true,\n        get: function reactiveGetter() {\n            ....\n            dep.depend()\n            return value\n            ....\n        },\n        set: function reactiveSetter(newVal) {\n            ....\n            val = newVal\n            dep.notify()\n            ....\n        }\n    })\n}","baseline":493,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"function defineReactive(obj, key) {\n    const dep = new Dep()\n\n    Object.defineProperty(obj, key,  {\n        enumerable: true,\n        configurable: true,\n        get: function reactiveGetter() {\n            ....\n            dep.depend()\n            return value\n            ....\n        },\n        set: function reactiveSetter(newVal) {\n            ....\n            val = newVal\n            dep.notify()\n            ....\n        }\n    })\n}"},{"type":"rectangle","version":250,"versionNonce":20239772,"isDeleted":false,"id":"dLPW4NEQ93DhJWUwjXlBi","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"dashed","roughness":2,"opacity":100,"angle":0,"x":680.0000000000002,"y":106.99999999999989,"strokeColor":"#000000","backgroundColor":"transparent","width":548.3333333333333,"height":450,"seed":191173752,"groupIds":[],"strokeSharpness":"sharp","boundElements":[],"updated":1766056878467,"link":null},{"type":"text","version":287,"versionNonce":2036458020,"isDeleted":false,"id":"bJSTGzrPHGs5TFTVfDb0q","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"dashed","roughness":2,"opacity":100,"angle":0,"x":706.6666666666667,"y":121.33333333333337,"strokeColor":"#000000","backgroundColor":"transparent","width":504,"height":425,"seed":1231280504,"groupIds":[],"strokeSharpness":"sharp","boundElements":[],"updated":1766056878467,"link":null,"fontSize":20,"fontFamily":1,"text":"class Dep {\n    static target: ?Watcher;\n    subs: Array<Watcher>;\n    \n    depend() {\n        if (Dep.target) {\n            Dep.target.addDep(this)\n        }\n    }\n\n    notify() {\n        const subs = this.subs.slice()\n        for (let i = 0, l = subs.length; i < l; i++) {\n            subs[i].update()\n        }\n    }\n}","baseline":418,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"class Dep {\n    static target: ?Watcher;\n    subs: Array<Watcher>;\n    \n    depend() {\n        if (Dep.target) {\n            Dep.target.addDep(this)\n        }\n    }\n\n    notify() {\n        const subs = this.subs.slice()\n        for (let i = 0, l = subs.length; i < l; i++) {\n            subs[i].update()\n        }\n    }\n}"},{"id":"9aabzn7RqLg53i5X4B_kW","type":"rectangle","x":108.16666666666663,"y":-2803.7857142857133,"width":176,"height":92.85714285714312,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"dashed","roughness":2,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":800959238,"version":20,"versionNonce":223317594,"isDeleted":false,"boundElements":[{"type":"text","id":"FD-ioAzkPvhmgLPMJc-n0"},{"id":"wW9hBOLs9_9Mla5h5XhzC","type":"arrow"}],"updated":1777531905463,"link":null},{"id":"FD-ioAzkPvhmgLPMJc-n0","type":"text","x":113.16666666666663,"y":-2769.8571428571418,"width":166,"height":25,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"dashed","roughness":2,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":614832922,"version":14,"versionNonce":762444890,"isDeleted":false,"boundElements":null,"updated":1777531899185,"link":null,"text":"same table","fontSize":20,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":18,"containerId":"9aabzn7RqLg53i5X4B_kW","originalText":"same table"},{"id":"wW9hBOLs9_9Mla5h5XhzC","type":"arrow","x":301.0238095238095,"y":-2758.0714285714275,"width":497.1428571428572,"height":125.71428571428578,"angle":0,